# =============================================================================
# Credenciais — preencha antes de rodar pela primeira vez
# =============================================================================

CAFE_USERNAME=change_this        # Ex: 202612345678910 (matrícula)
CAFE_PASSWORD=change_this        # Senha do portal acadêmico
                                 # Suporte a pass(1): PASS:path/no/cofre
CAFE_INSTITUTION_ID=change_this  # Ex: IFCE, UFRJ, USP

# =============================================================================
# URLs de acesso (padrão CAPES/CAFe — só altere se a sua instituição for diferente)
# =============================================================================

CAFE_ACCESS_URL="https://www.periodicos.capes.gov.br/index.php/acesso-cafe.html"
SCOPUS_HOME_URL="https://www-scopus-com.ez138.periodicos.capes.gov.br/"
SCOPUS_RESULTS_URL="https://www-scopus-com.ez138.periodicos.capes.gov.br/results/results.uri"

# =============================================================================
# Comportamento do login CAFe
# =============================================================================

CAFE_LOGIN_AUTOFILL_MODE=both    # username | password | both — campos a preencher automaticamente
CAFE_AUTO_CLICK_LOGIN=false      # true = clica no botão de login sem intervenção manual
CAFE_STEP_DELAY_MS=1200          # ms de pausa entre cada etapa do fluxo de login

# =============================================================================
# Velocidade do Playwright (aumente se tiver erros de timeout)
# =============================================================================

SLOW_MO=50                       # ms de delay entre cada ação do browser
DELAY_MS=1500                    # ms de pausa entre artigos na extração de keywords

# =============================================================================
# Chromium (opcional — detectado automaticamente se omitido)
# =============================================================================

# CHROMIUM_EXECUTABLE_PATH=
# Linux:   /usr/bin/chromium
# macOS:   ~/Library/Caches/ms-playwright/chromium-XXXX/chrome-mac/Chromium.app/Contents/MacOS/Chromium
# Windows: %LOCALAPPDATA%\ms-playwright\chromium-XXXX\chrome-win\chrome.exe
