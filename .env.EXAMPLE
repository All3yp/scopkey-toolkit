CAFE_ACCESS_URL="https://www.periodicos.capes.gov.br/index.php/acesso-cafe.html"
SCOPUS_HOME_URL="https://www-scopus-com.ez138.periodicos.capes.gov.br/"
SCOPUS_RESULTS_URL="https://www-scopus-com.ez138.periodicos.capes.gov.br/results/results.uri"


CAFE_USERNAME=change_this # Ex: 202612345678910 (Matricula)
CAFE_PASSWORD=change_this # Senha Academico portal

CAFE_INSTITUTION_ID=change_this # Ex: IFCE

SLOW_MO=50                        # ms de delay entre cada ação do Playwright (mais alto = mais lento, mais estável)
DELAY_MS=1500                     # ms de pausa entre cada artigo na extração de keywords
CAFE_STEP_DELAY_MS=1200           # ms de pausa entre cada etapa do fluxo de login CAFe
CAFE_AUTO_CLICK_LOGIN=false       # true = clica no botão de login automaticamente após preencher
CAFE_LOGIN_AUTOFILL_MODE=both     # username | password | both — quais campos preencher automaticamente
# CHROMIUM_EXECUTABLE_PATH=  (opcional — Playwright usa o browser instalado automaticamente)
# Linux:   /home/<user>/.cache/ms-playwright/chromium-XXXX/chrome-linux64/chrome
# macOS:   /Users/<user>/Library/Caches/ms-playwright/chromium-XXXX/chrome-mac/Chromium.app/Contents/MacOS/Chromium
# Windows: C:\Users\<user>\AppData\Local\ms-playwright\chromium-XXXX\chrome-win\chrome.exe